{
  "manifest_version": 3,
  "name": "Job Form Autofiller",
  "version": "1.0.0",
  "description": "Autofills standard job application fields with fuzzy matching.",
  "permissions": ["activeTab", "scripting", "storage"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Autofill Form",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": ["user-data.json"],
      "matches": ["<all_urls>"]
    }
  ]
}